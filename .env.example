# DropRaw Web example environment.
# Copy to .env for local use. Never commit real tokens or credentials.

DROPBOX_ACCESS_TOKEN=

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
S3_ENDPOINT_URL=

DROPRAW_UI_ALLOWED_SOURCE_ROOTS=/input
DROPRAW_UI_ALLOWED_OUTPUT_ROOTS=/output
